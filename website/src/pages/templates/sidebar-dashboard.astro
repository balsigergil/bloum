---
import "../../styles/global.css";
import "../../../../src/bloum.css";
import Head from "../../components/head.astro";
---

<html lang="en">
  <head>
    <Head />
    <title>Bloum - Sidebar Dashboard Template</title>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    />
  </head>
  <body class="bg-white text-slate-900 antialiased">
    <div class="app">
      <aside class="sidebar" id="collapsible-sidebar">
        <div class="sidebar-content">
          <div class="sidebar-top">
            <div class="sidebar-brand">
              <a href="#">
                <img
                  src="https://raw.githubusercontent.com/balsigergil/bloum/main/.github/bloum_logo.png"
                  class="dark:hidden"
                  alt="Bloum Logo"
                  width="200"
                />
                <img
                  src="https://raw.githubusercontent.com/balsigergil/bloum/main/.github/bloum_logo_light.png"
                  class="hidden dark:block"
                  alt="Bloum Logo"
                  width="200"
                />
              </a>
            </div>
            <div class="mx-4">
              <div class="input-icon">
                <span class="input-icon-addon">
                  <i class="fa-solid fa-magnifying-glass"></i>
                </span>
                <input type="search" class="input" placeholder="Search..." />
              </div>
            </div>
            <h3 class="sidebar-group-title mt-2">Dashboard</h3>
            <ul class="sidebar-nav">
              <li class="sidebar-item active">
                <a href="#" class="sidebar-link">
                  <i class="fa-solid fa-home fa-fw"></i>
                  Home
                </a>
              </li>
              <li class="sidebar-item">
                <a href="#" class="sidebar-link">
                  <i class="fa-solid fa-bars-progress fa-fw"></i>
                  Projects
                </a>
              </li>
              <li class="sidebar-item">
                <a href="#" class="sidebar-link">
                  <i class="fa-solid fa-list-check fa-fw"></i>
                  Tasks
                </a>
              </li>
              <!-- Collapsible User Management Section -->
              <li class="sidebar-item">
                <button
                  class="sidebar-link sidebar-collapsible-trigger"
                  data-collapse="#users-menu"
                  aria-expanded="false"
                >
                  <i class="fa-solid fa-users fa-fw"></i>
                  User Management
                </button>
                <div
                  id="users-menu"
                  class="collapsible sidebar-collapsible-content"
                >
                  <div class="sidebar-item">
                    <a href="#" class="sidebar-link">
                      <i class="fa-solid fa-users-line fa-fw"></i>
                      All Users
                    </a>
                  </div>
                  <div class="sidebar-item">
                    <a href="#" class="sidebar-link">
                      <i class="fa-solid fa-user-shield fa-fw"></i>
                      User Roles
                    </a>
                  </div>
                  <div class="sidebar-item">
                    <a href="#" class="sidebar-link">
                      <i class="fa-solid fa-key fa-fw"></i>
                      Permissions
                    </a>
                  </div>
                </div>
              </li>
            </ul>
            <h3 class="sidebar-group-title">Administration</h3>
            <ul class="sidebar-nav">
              <!-- Collapsible Finance Section -->
              <li class="sidebar-item">
                <button
                  class="sidebar-collapsible-trigger sidebar-link"
                  data-collapse="#finance-menu"
                  aria-expanded="false"
                >
                  <i class="fa-solid fa-dollar fa-fw"></i>
                  Finance
                </button>
                <div
                  id="finance-menu"
                  class="collapsible sidebar-collapsible-content"
                >
                  <div class="sidebar-item">
                    <a href="#" class="sidebar-link">
                      <i class="fa-solid fa-chart-line fa-fw"></i>
                      Revenue
                    </a>
                  </div>
                  <div class="sidebar-item">
                    <a href="#" class="sidebar-link">
                      <i class="fa-solid fa-credit-card fa-fw"></i>
                      Expenses
                    </a>
                  </div>
                  <div class="sidebar-item">
                    <a href="#" class="sidebar-link">
                      <i class="fa-solid fa-file-invoice fa-fw"></i>
                      Invoices
                    </a>
                  </div>
                  <div class="sidebar-item">
                    <a href="#" class="sidebar-link">
                      <i class="fa-solid fa-calculator fa-fw"></i>
                      Budgets
                    </a>
                  </div>
                </div>
              </li>
              <li class="sidebar-item">
                <a href="#" class="sidebar-link">
                  <i class="fa-solid fa-file fa-fw"></i>
                  Reports
                </a>
              </li>
              <li class="sidebar-item">
                <a href="#" class="sidebar-link">
                  <i class="fa-solid fa-wrench fa-fw"></i>
                  Parameters
                </a>
              </li>
            </ul>
          </div>
          <div class="sidebar-bottom">
            <ul class="sidebar-nav">
              <li class="sidebar-item">
                <a href="#" class="sidebar-link">
                  <i class="fa-solid fa-circle-question fa-fw"></i>
                  Help
                </a>
              </li>
              <li class="sidebar-item">
                <a href="#" class="sidebar-link">
                  <i class="fa-solid fa-cog fa-fw"></i>
                  Settings
                </a>
              </li>
              <li class="sidebar-item">
                <form action="" method="post">
                  <button class="sidebar-link" type="submit">
                    <i class="fa-solid fa-sign-out fa-fw"></i>
                    Logout
                  </button>
                </form>
              </li>
            </ul>
            <div class="p-4 flex justify-between items-center">
              <div class="flex items-center gap-4">
                <div
                  class="rounded-full bg-gray-500 text-white size-10 grid place-items-center font-semibold"
                >
                  GB
                </div>
                <div>
                  <div class="font-semibold">John Doe</div>
                  <div class="text-light dark:text-gray-400">Administrator</div>
                </div>
              </div>
              <div class="dropdown">
                <button
                  class="btn btn-icon btn-ghost btn-sm"
                  data-dropdown-toggle
                >
                  <i class="fa-solid fa-ellipsis-vertical"></i>
                </button>
                <div class="menu">
                  <div class="menu-group">
                    <div class="menu-label">My Account</div>
                    <a href="#" class="menu-item"
                      ><i class="fas fa-fw fa-user"></i>Profile</a
                    >
                    <a href="#" class="menu-item"
                      ><i class="fas fa-fw fa-cog"></i>Settings</a
                    >
                  </div>
                  <div class="menu-divider"></div>
                  <div class="menu-group">
                    <button class="menu-item">
                      <i class="fas fa-fw fa-right-from-bracket"></i> Logout
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </aside>
      <header class="topbar">
        <button
          class="btn btn-icon btn-ghost btn-sidebar-toggle"
          data-sidebar="#collapsible-sidebar"
        >
          <i class="fa-solid fa-bars"></i>
        </button>
        <div class="topbar-center">
          <img
            src="https://raw.githubusercontent.com/balsigergil/bloum/main/.github/bloum_logo_light.png"
            class="dark:hidden"
            alt="Bloum Logo"
            width="150"
          />
          <img
            src="https://raw.githubusercontent.com/balsigergil/bloum/main/.github/bloum_logo.png"
            class="hidden"
            alt="Bloum Logo"
            width="150"
          />
        </div>
      </header>
      <main class="main p-6">
        <!-- Page header -->
        <div class="flex justify-between items-center mb-6">
          <div>
            <h2 class="text-light uppercase tracking-wider text-sm font-medium">
              Overview
            </h2>
            <h1 class="font-semibold text-2xl">Dashboard</h1>
          </div>
          <div class="flex gap-2">
            <button class="btn btn-outline">
              <i class="fas fa-download fa-fw"></i>Export
            </button>
            <button class="btn btn-primary" data-modal="#form-modal">
              <i class="fas fa-user-plus fa-fw"></i>New member
            </button>
          </div>
        </div>

        <!-- KPI cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
          <div class="card">
            <div class="card-body">
              <div class="flex justify-between items-start">
                <div>
                  <p class="text-light text-sm uppercase tracking-wide">
                    Total Users
                  </p>
                  <h3 class="font-semibold text-3xl mt-1">2,847</h3>
                </div>
                <div
                  class="size-10 rounded-lg bg-blue-100 text-blue-600 grid place-items-center"
                >
                  <i class="fas fa-users"></i>
                </div>
              </div>
              <p class="text-sm mt-3">
                <span class="text-green-600 font-medium"
                  ><i class="fas fa-arrow-up"></i> 12.5%</span
                >
                <span class="text-light ml-1">vs last month</span>
              </p>
            </div>
          </div>
          <div class="card">
            <div class="card-body">
              <div class="flex justify-between items-start">
                <div>
                  <p class="text-light text-sm uppercase tracking-wide">
                    Revenue
                  </p>
                  <h3 class="font-semibold text-3xl mt-1">$48.2k</h3>
                </div>
                <div
                  class="size-10 rounded-lg bg-green-100 text-green-600 grid place-items-center"
                >
                  <i class="fas fa-dollar-sign"></i>
                </div>
              </div>
              <p class="text-sm mt-3">
                <span class="text-green-600 font-medium"
                  ><i class="fas fa-arrow-up"></i> 8.2%</span
                >
                <span class="text-light ml-1">vs last month</span>
              </p>
            </div>
          </div>
          <div class="card">
            <div class="card-body">
              <div class="flex justify-between items-start">
                <div>
                  <p class="text-light text-sm uppercase tracking-wide">
                    Active Projects
                  </p>
                  <h3 class="font-semibold text-3xl mt-1">24</h3>
                </div>
                <div
                  class="size-10 rounded-lg bg-purple-100 text-purple-600 grid place-items-center"
                >
                  <i class="fas fa-folder-open"></i>
                </div>
              </div>
              <p class="text-sm mt-3">
                <span class="text-red-600 font-medium"
                  ><i class="fas fa-arrow-down"></i> 3.1%</span
                >
                <span class="text-light ml-1">vs last month</span>
              </p>
            </div>
          </div>
          <div class="card">
            <div class="card-body">
              <div class="flex justify-between items-start">
                <div>
                  <p class="text-light text-sm uppercase tracking-wide">
                    Pending Tasks
                  </p>
                  <h3 class="font-semibold text-3xl mt-1">18</h3>
                </div>
                <div
                  class="size-10 rounded-lg bg-orange-100 text-orange-600 grid place-items-center"
                >
                  <i class="fas fa-clock"></i>
                </div>
              </div>
              <p class="text-sm mt-3">
                <span class="text-green-600 font-medium"
                  ><i class="fas fa-arrow-down"></i> 24%</span
                >
                <span class="text-light ml-1">vs last month</span>
              </p>
            </div>
          </div>
        </div>

        <!-- Main content row -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-6">
          <!-- Users table (spans 2 cols) -->
          <div class="card lg:col-span-2">
            <div class="card-header">
              <h3 class="card-title">Team Members</h3>
              <div class="card-actions">
                <button
                  class="btn btn-sm btn-icon btn-ghost"
                  aria-label="Add user"
                >
                  <i class="fas fa-plus"></i>
                </button>
                <div class="dropdown">
                  <button
                    class="btn btn-sm btn-icon btn-ghost"
                    data-dropdown-toggle
                    aria-label="More options"
                  >
                    <i class="fas fa-ellipsis-vertical"></i>
                  </button>
                  <div class="menu">
                    <div class="menu-group">
                      <button class="menu-item">
                        <i class="fas fa-fw fa-download"></i>Export CSV
                      </button>
                      <button class="menu-item">
                        <i class="fas fa-fw fa-print"></i>Print
                      </button>
                    </div>
                    <div class="menu-divider"></div>
                    <div class="menu-group">
                      <button class="menu-item">
                        <i class="fas fa-fw fa-cog"></i>Table settings
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div class="table-responsive">
              <table class="table">
                <thead>
                  <tr>
                    <th>
                      <input
                        type="checkbox"
                        class="input-check"
                        aria-label="Select all"
                      />
                    </th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th><span class="sr-only">Actions</span></th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>
                      <input
                        type="checkbox"
                        class="input-check"
                        aria-label="Select user"
                      />
                    </td>
                    <td>
                      <div class="flex items-center gap-3">
                        <div class="avatar avatar-sm">
                          <span class="avatar-initials">SL</span>
                        </div>
                        Sarah Laurent
                      </div>
                    </td>
                    <td>s.laurent@company.com</td>
                    <td>Admin</td>
                    <td><span class="tag tag-success">Active</span></td>
                    <td>
                      <button
                        class="btn btn-icon btn-xs btn-ghost"
                        aria-label="Edit user"
                      >
                        <i class="fas fa-pen"></i>
                      </button>
                      <button
                        class="btn btn-icon btn-xs btn-ghost"
                        aria-label="Delete user"
                      >
                        <i class="fas fa-trash"></i>
                      </button>
                    </td>
                  </tr>
                  <tr>
                    <td>
                      <input
                        type="checkbox"
                        class="input-check"
                        aria-label="Select user"
                      />
                    </td>
                    <td>
                      <div class="flex items-center gap-3">
                        <div class="avatar avatar-sm">
                          <span class="avatar-initials">MR</span>
                        </div>
                        Marc Renaud
                      </div>
                    </td>
                    <td>m.renaud@company.com</td>
                    <td>Editor</td>
                    <td><span class="tag tag-success">Active</span></td>
                    <td>
                      <button
                        class="btn btn-icon btn-xs btn-ghost"
                        aria-label="Edit user"
                      >
                        <i class="fas fa-pen"></i>
                      </button>
                      <button
                        class="btn btn-icon btn-xs btn-ghost"
                        aria-label="Delete user"
                      >
                        <i class="fas fa-trash"></i>
                      </button>
                    </td>
                  </tr>
                  <tr>
                    <td>
                      <input
                        type="checkbox"
                        class="input-check"
                        aria-label="Select user"
                      />
                    </td>
                    <td>
                      <div class="flex items-center gap-3">
                        <div class="avatar avatar-sm">
                          <span class="avatar-initials">CP</span>
                        </div>
                        Claire Petit
                      </div>
                    </td>
                    <td>c.petit@company.com</td>
                    <td>Viewer</td>
                    <td><span class="tag tag-warning">Away</span></td>
                    <td>
                      <button
                        class="btn btn-icon btn-xs btn-ghost"
                        aria-label="Edit user"
                      >
                        <i class="fas fa-pen"></i>
                      </button>
                      <button
                        class="btn btn-icon btn-xs btn-ghost"
                        aria-label="Delete user"
                      >
                        <i class="fas fa-trash"></i>
                      </button>
                    </td>
                  </tr>
                  <tr>
                    <td>
                      <input
                        type="checkbox"
                        class="input-check"
                        aria-label="Select user"
                      />
                    </td>
                    <td>
                      <div class="flex items-center gap-3">
                        <div class="avatar avatar-sm">
                          <span class="avatar-initials">TD</span>
                        </div>
                        Thomas Dubois
                      </div>
                    </td>
                    <td>t.dubois@company.com</td>
                    <td>Editor</td>
                    <td><span class="tag tag-success">Active</span></td>
                    <td>
                      <button
                        class="btn btn-icon btn-xs btn-ghost"
                        aria-label="Edit user"
                      >
                        <i class="fas fa-pen"></i>
                      </button>
                      <button
                        class="btn btn-icon btn-xs btn-ghost"
                        aria-label="Delete user"
                      >
                        <i class="fas fa-trash"></i>
                      </button>
                    </td>
                  </tr>
                  <tr>
                    <td>
                      <input
                        type="checkbox"
                        class="input-check"
                        aria-label="Select user"
                      />
                    </td>
                    <td>
                      <div class="flex items-center gap-3">
                        <div class="avatar avatar-sm">
                          <span class="avatar-initials">EM</span>
                        </div>
                        Emma Martin
                      </div>
                    </td>
                    <td>e.martin@company.com</td>
                    <td>Viewer</td>
                    <td><span class="tag">Inactive</span></td>
                    <td>
                      <button
                        class="btn btn-icon btn-xs btn-ghost"
                        aria-label="Edit user"
                      >
                        <i class="fas fa-pen"></i>
                      </button>
                      <button
                        class="btn btn-icon btn-xs btn-ghost"
                        aria-label="Delete user"
                      >
                        <i class="fas fa-trash"></i>
                      </button>
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Recent activity -->
          <div class="card">
            <div class="card-header">
              <h3 class="card-title">Recent Activity</h3>
              <div class="card-actions">
                <a href="#" class="btn btn-sm btn-ghost">View all</a>
              </div>
            </div>
            <div class="card-body">
              <div class="space-y-4">
                <div class="flex gap-3">
                  <div
                    class="size-8 rounded-full bg-blue-100 text-blue-600 grid place-items-center shrink-0"
                  >
                    <i class="fas fa-user-plus text-xs"></i>
                  </div>
                  <div>
                    <p class="text-sm">
                      <strong>Sarah Laurent</strong> added a new team member
                    </p>
                    <p class="text-xs text-light">2 minutes ago</p>
                  </div>
                </div>
                <div class="flex gap-3">
                  <div
                    class="size-8 rounded-full bg-green-100 text-green-600 grid place-items-center shrink-0"
                  >
                    <i class="fas fa-check text-xs"></i>
                  </div>
                  <div>
                    <p class="text-sm">
                      <strong>Marc Renaud</strong> completed project
                      <em>Website Redesign</em>
                    </p>
                    <p class="text-xs text-light">18 minutes ago</p>
                  </div>
                </div>
                <div class="flex gap-3">
                  <div
                    class="size-8 rounded-full bg-orange-100 text-orange-600 grid place-items-center shrink-0"
                  >
                    <i class="fas fa-file-invoice text-xs"></i>
                  </div>
                  <div>
                    <p class="text-sm">
                      <strong>System</strong> generated invoice
                      <em>#INV-2024-0892</em>
                    </p>
                    <p class="text-xs text-light">1 hour ago</p>
                  </div>
                </div>
                <div class="flex gap-3">
                  <div
                    class="size-8 rounded-full bg-red-100 text-red-600 grid place-items-center shrink-0"
                  >
                    <i class="fas fa-shield-halved text-xs"></i>
                  </div>
                  <div>
                    <p class="text-sm">
                      <strong>Claire Petit</strong> updated role permissions for
                      <em>Editor</em>
                    </p>
                    <p class="text-xs text-light">3 hours ago</p>
                  </div>
                </div>
                <div class="flex gap-3">
                  <div
                    class="size-8 rounded-full bg-purple-100 text-purple-600 grid place-items-center shrink-0"
                  >
                    <i class="fas fa-code-branch text-xs"></i>
                  </div>
                  <div>
                    <p class="text-sm">
                      <strong>Thomas Dubois</strong> deployed
                      <em>v2.4.1</em> to production
                    </p>
                    <p class="text-xs text-light">5 hours ago</p>
                  </div>
                </div>
                <div class="flex gap-3">
                  <div
                    class="size-8 rounded-full bg-blue-100 text-blue-600 grid place-items-center shrink-0"
                  >
                    <i class="fas fa-comment text-xs"></i>
                  </div>
                  <div>
                    <p class="text-sm">
                      <strong>Emma Martin</strong> commented on task
                      <em>API Integration</em>
                    </p>
                    <p class="text-xs text-light">Yesterday</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Bottom row -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
          <!-- Open tasks -->
          <div class="card lg:col-span-2">
            <div class="card-header">
              <h3 class="card-title">Open Tasks</h3>
              <div class="card-actions">
                <button class="btn btn-sm btn-outline">
                  <i class="fas fa-plus fa-fw"></i>Add task
                </button>
              </div>
            </div>
            <div class="card-body p-0 mt-2">
              <div class="divide-y">
                <div class="flex items-center gap-4 px-6 py-3">
                  <input type="checkbox" class="input-check" />
                  <div class="flex-1 min-w-0">
                    <p class="font-medium">Review Q1 financial report</p>
                    <p class="text-sm text-light">Assigned to Sarah Laurent</p>
                  </div>
                  <span class="tag tag-danger">High</span>
                  <span class="text-sm text-light">Due Apr 15</span>
                </div>
                <div class="flex items-center gap-4 px-6 py-3">
                  <input type="checkbox" class="input-check" />
                  <div class="flex-1 min-w-0">
                    <p class="font-medium">Update user onboarding flow</p>
                    <p class="text-sm text-light">Assigned to Marc Renaud</p>
                  </div>
                  <span class="tag tag-warning">Medium</span>
                  <span class="text-sm text-light">Due Apr 18</span>
                </div>
                <div class="flex items-center gap-4 px-6 py-3">
                  <input type="checkbox" class="input-check" />
                  <div class="flex-1 min-w-0">
                    <p class="font-medium">Migrate database to new cluster</p>
                    <p class="text-sm text-light">Assigned to Thomas Dubois</p>
                  </div>
                  <span class="tag tag-danger">High</span>
                  <span class="text-sm text-light">Due Apr 12</span>
                </div>
                <div class="flex items-center gap-4 px-6 py-3">
                  <input type="checkbox" class="input-check" />
                  <div class="flex-1 min-w-0">
                    <p class="font-medium">Design new landing page mockups</p>
                    <p class="text-sm text-light">Assigned to Claire Petit</p>
                  </div>
                  <span class="tag tag-info">Low</span>
                  <span class="text-sm text-light">Due Apr 22</span>
                </div>
                <div class="flex items-center gap-4 px-6 py-3">
                  <input type="checkbox" class="input-check" />
                  <div class="flex-1 min-w-0">
                    <p class="font-medium">Fix authentication timeout issue</p>
                    <p class="text-sm text-light">Assigned to Thomas Dubois</p>
                  </div>
                  <span class="tag tag-warning">Medium</span>
                  <span class="text-sm text-light">Due Apr 14</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Quick stats -->
          <div class="space-y-4">
            <div class="card">
              <div class="card-header">
                <h3 class="card-title">Storage</h3>
              </div>
              <div class="card-body">
                <div class="flex justify-between text-sm mb-2">
                  <span>68.4 GB used</span>
                  <span class="text-light">100 GB</span>
                </div>
                <div class="progress">
                  <div class="progress-bar" style="width: 68%"></div>
                </div>
                <p class="text-xs text-light mt-2">31.6 GB remaining</p>
              </div>
            </div>
            <div class="card">
              <div class="card-header">
                <h3 class="card-title">Uptime</h3>
              </div>
              <div class="card-body">
                <div class="flex items-baseline gap-2">
                  <h3 class="font-semibold text-3xl">99.98%</h3>
                  <span class="text-sm text-light">last 30 days</span>
                </div>
                <div class="mt-3 space-y-2">
                  <div class="flex justify-between text-sm">
                    <span>API</span>
                    <span class="text-green-600 font-medium">Operational</span>
                  </div>
                  <div class="flex justify-between text-sm">
                    <span>Database</span>
                    <span class="text-green-600 font-medium">Operational</span>
                  </div>
                  <div class="flex justify-between text-sm">
                    <span>CDN</span>
                    <span class="text-green-600 font-medium">Operational</span>
                  </div>
                  <div class="flex justify-between text-sm">
                    <span>Worker Queue</span>
                    <span class="text-orange-500 font-medium">Degraded</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Create user modal -->
        <div class="modal" id="form-modal" aria-labelledby="form-modal-title">
          <div class="modal-content modal-lg">
            <div class="modal-header">
              <h3 class="modal-title" id="form-modal-title">Add Team Member</h3>
              <button
                type="button"
                class="btn btn-icon btn-ghost"
                aria-label="Close"
                data-modal-close
              >
                <i class="fas fa-times"></i>
              </button>
            </div>
            <div class="modal-body">
              <form id="user-form">
                <div
                  style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;"
                >
                  <div class="field">
                    <label for="first-name" class="label">First Name</label>
                    <input
                      type="text"
                      id="first-name"
                      name="firstName"
                      class="input"
                      placeholder="John"
                      required
                    />
                  </div>
                  <div class="field">
                    <label for="last-name" class="label">Last Name</label>
                    <input
                      type="text"
                      id="last-name"
                      name="lastName"
                      class="input"
                      placeholder="Doe"
                      required
                    />
                  </div>
                </div>

                <div class="field">
                  <label for="user-email" class="label">Email Address</label>
                  <input
                    type="email"
                    id="user-email"
                    name="email"
                    class="input"
                    placeholder="john.doe@company.com"
                    required
                  />
                </div>

                <div class="field">
                  <label for="user-role" class="label">Role</label>
                  <select id="user-role" name="role" class="input" required>
                    <option value="">Select a role</option>
                    <option value="admin">Administrator</option>
                    <option value="editor">Editor</option>
                    <option value="viewer">Viewer</option>
                  </select>
                </div>

                <div class="field">
                  <label for="user-bio" class="label">Bio</label>
                  <textarea
                    id="user-bio"
                    name="bio"
                    class="input"
                    rows="3"
                    placeholder="Tell us about yourself..."></textarea>
                </div>

                <div class="field">
                  <div class="field">
                    <input
                      type="checkbox"
                      class="input-check"
                      id="notifications"
                      name="notifications"
                      checked
                    />
                    <label class="label" for="notifications"
                      >Send welcome email</label
                    >
                  </div>
                </div>
              </form>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-outline" data-modal-close
                >Cancel</button
              >
              <button type="submit" form="user-form" class="btn btn-primary"
                >Add Member</button
              >
            </div>
          </div>
        </div>
      </main>
    </div>

    <script>
      import { init } from "../../../../src";
      init();
    </script>
  </body>
</html>
