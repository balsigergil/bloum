---
import Layout from "../layouts/layout.astro";
---

<Layout title="Templates">
  <div class="mx-auto max-w-7xl px-6 py-12">
    <h1 class="text-4xl font-bold text-center text-slate-800 mb-4">
      Templates
    </h1>
    <p class="text-center text-slate-500 mb-12 max-w-2xl mx-auto">
      Ready-to-use page templates built with Bloum.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      <!-- Sidebar Dashboard Template -->
      <div class="card">
        <div class="card-header">
          <h3 class="card-title">Dashboard with Collapsible Sidebar</h3>
          <p class="card-description">
            An admin dashboard layout featuring a sidebar with collapsible menu
            sections and a content area with cards and tables.
          </p>
        </div>
        <div class="card-footer">
          <a href="/templates/sidebar-dashboard" class="btn btn-primary w-full">
            <i class="fa-solid fa-eye"></i>
            Preview
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>
