---
import "@fontsource-variable/figtree/wght.css";
import "@fontsource-variable/geist/wght.css";
import "@fontsource-variable/roboto/wght.css";
import Layout from "../layouts/layout.astro";
import Section from "../components/component-section.astro";
import Demo from "../components/component-demo.astro";
import FontSelector from "../components/font-selector.astro";
---

<Layout title="Components">
  <div class="mx-auto max-w-7xl px-6 py-12">
    <h1 class="text-4xl font-bold text-center text-slate-800 mb-4">
      Components
    </h1>
    <p class="text-center text-slate-500 max-w-2xl mx-auto">
      A showcase of all Bloum components. Each component is fully interactive.
    </p>

    <div class="max-w-32 mx-auto my-4">
      <FontSelector />
    </div>

    <!-- Quick nav -->
    <nav class="mb-12 flex flex-wrap justify-center gap-2">
      <a href="#elements" class="btn btn-ghost">Elements</a>
      <a href="#inputs" class="btn btn-ghost">Inputs</a>
      <a href="#data" class="btn btn-ghost">Data Display</a>
      <a href="#overlays" class="btn btn-ghost">Overlays</a>
      <a href="#layout" class="btn btn-ghost">Layout</a>
    </nav>

    <!-- ==================== ELEMENTS ==================== -->
    <Section title="Elements" id="elements">
      <!-- Button -->
      <Demo title="Button">
        <div class="flex flex-wrap items-center gap-3">
          <button class="btn btn-primary">Primary</button>
          <button class="btn btn-danger">Danger</button>
          <button class="btn btn-success">Success</button>
          <button class="btn btn-warning">Warning</button>
          <button class="btn btn-info">Info</button>
          <button class="btn btn-default">Default</button>
        </div>
        <div class="flex flex-wrap items-center gap-3 mt-4">
          <button class="btn btn-outline btn-primary">Outline</button>
          <button class="btn btn-ghost btn-primary">Ghost</button>
          <button class="btn btn-primary btn-sm">Small</button>
          <button class="btn btn-primary btn-lg">Large</button>
          <button class="btn btn-primary btn-loading">Loading</button>
          <button class="btn btn-primary" disabled>Disabled</button>
        </div>
        <div class="flex flex-wrap items-center gap-3 mt-4">
          <button class="btn btn-icon btn-primary">
            <i class="fas fa-plus"></i>
          </button>
          <button class="btn btn-icon btn-outline btn-primary">
            <i class="fas fa-pen"></i>
          </button>
          <button class="btn btn-icon btn-ghost">
            <i class="fas fa-trash"></i>
          </button>
          <button class="btn btn-primary">
            <i class="fas fa-paper-plane"></i> Send
          </button>
        </div>
      </Demo>

      <!-- Badge -->
      <Demo title="Badge">
        <div class="flex flex-wrap items-center gap-4">
          <button class="btn">
            Messages
            <span class="badge">5</span>
          </button>
          <button class="btn">
            Alerts
            <span class="badge badge-danger">12</span>
          </button>
          <button class="btn">
            Updates
            <span class="badge badge-success">3</span>
          </button>
          <button class="btn">
            Notifications
            <span class="badge badge-danger badge-top-right">3</span>
          </button>
          <button class="btn">
            Status
            <span
              class="badge badge-success badge-top-right badge-dot badge-ping"
            ></span>
          </button>
        </div>
      </Demo>

      <!-- Tag -->
      <Demo title="Tag">
        <div class="flex flex-wrap items-center gap-3">
          <div class="tag tag-primary">
            <span class="tag-text">Primary</span>
          </div>
          <div class="tag tag-success">
            <span class="tag-text">Success</span>
          </div>
          <div class="tag tag-danger">
            <span class="tag-text">Danger</span>
          </div>
          <div class="tag tag-warning">
            <span class="tag-text">Warning</span>
          </div>
          <div class="tag tag-info">
            <span class="tag-text">Info</span>
          </div>
        </div>
        <div class="flex flex-wrap items-center gap-3 mt-4">
          <div class="tag tag-primary tag-solid">
            <span class="tag-text">Solid</span>
          </div>
          <div class="tag tag-primary tag-rounded">
            <span class="tag-text">Rounded</span>
          </div>
          <div class="tag tag-primary tag-sm">
            <span class="tag-text">Small</span>
          </div>
          <div class="tag tag-primary tag-lg">
            <span class="tag-text">Large</span>
          </div>
          <div class="tag tag-danger">
            <span class="tag-text">Removable</span>
            <button class="tag-remove" type="button"></button>
          </div>
        </div>
      </Demo>

      <!-- Avatar -->
      <Demo title="Avatar">
        <div class="flex flex-wrap items-end gap-4">
          <div class="avatar avatar-xs" data-avatar data-avatar-initials="XS">
          </div>
          <div class="avatar avatar-sm" data-avatar data-avatar-initials="SM">
          </div>
          <div class="avatar" data-avatar data-avatar-initials="MD"></div>
          <div class="avatar avatar-lg" data-avatar data-avatar-initials="LG">
          </div>
          <div class="avatar avatar-xl" data-avatar data-avatar-initials="XL">
          </div>
        </div>
        <div class="flex flex-wrap items-center gap-4 mt-4">
          <div
            class="avatar"
            data-avatar
            data-avatar-initials="DF"
            data-avatar-variant="default"
          >
          </div>
          <div
            class="avatar"
            data-avatar
            data-avatar-initials="SL"
            data-avatar-variant="solid"
          >
          </div>
          <div
            class="avatar"
            data-avatar
            data-avatar-initials="OL"
            data-avatar-variant="outline"
          >
          </div>
          <div
            class="avatar"
            data-avatar
            data-avatar-initials="SB"
            data-avatar-variant="subtle"
          >
          </div>
        </div>
      </Demo>

      <!-- Alert -->
      <Demo title="Alert">
        <div class="space-y-4">
          <div class="alert">
            <div class="alert-icon"><i class="fas fa-info-circle"></i></div>
            <div class="alert-content">
              <div class="alert-title">Neutral alert</div>
              <div class="alert-text">This is a general message.</div>
            </div>
          </div>
          <div class="alert alert-primary">
            <div class="alert-icon"><i class="fas fa-info-circle"></i></div>
            <div class="alert-content">
              <div class="alert-title">Information</div>
              <div class="alert-text">
                This is an informational alert message.
              </div>
            </div>
          </div>
          <div class="alert alert-success">
            <div class="alert-icon"><i class="fas fa-check-circle"></i></div>
            <div class="alert-content">
              <div class="alert-title">Success</div>
              <div class="alert-text">Operation completed successfully.</div>
            </div>
          </div>
          <div class="alert alert-warning">
            <div class="alert-icon">
              <i class="fas fa-exclamation-triangle"></i>
            </div>
            <div class="alert-content">
              <div class="alert-title">Warning</div>
              <div class="alert-text">Please review before proceeding.</div>
            </div>
          </div>
          <div class="alert alert-danger">
            <div class="alert-icon">
              <i class="fas fa-exclamation-circle"></i>
            </div>
            <div class="alert-content">
              <div class="alert-title">Error</div>
              <div class="alert-text">Something went wrong.</div>
            </div>
          </div>
        </div>
      </Demo>

      <!-- Card -->
      <Demo title="Card">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="card">
            <div class="card-header">
              <h3 class="card-title">List of users</h3>
              <p class="card-description">
                Lorem ipsum dolor sit amet, consectetur adipisicing elit.
                Aliquid animi asperiores assumenda at corporis debitis dolore.
              </p>
              <div class="card-actions">
                <button
                  class="btn btn-sm btn-icon btn-ghost"
                  aria-label="Add user"
                >
                  <i class="fas fa-plus"></i>
                </button>
                <button
                  class="btn btn-sm btn-icon btn-ghost"
                  aria-label="Settings"
                >
                  <i class="fas fa-cog"></i>
                </button>
              </div>
            </div>
            <div class="card-body">
              Lorem ipsum dolor sit amet, consectetur adipisicing elit. Corporis
              culpa cumque ea exercitationem neque nulla.
            </div>
            <div class="card-footer">
              <button class="btn btn-primary">Save</button>
              <button class="btn btn-outline">Cancel</button>
            </div>
          </div>
          <div class="card">
            <div class="card-header">
              <h3 class="card-title">Simple card</h3>
            </div>
            <div class="card-body">
              A card with only a body section. Useful for simple content blocks.
            </div>
          </div>
        </div>
      </Demo>

      <!-- Spinner -->
      <Demo title="Spinner">
        <div class="flex flex-wrap items-center gap-6">
          <span class="spinner spinner-sm"></span>
          <span class="spinner"></span>
          <span class="spinner spinner-lg"></span>
          <span class="spinner spinner-xl"></span>
        </div>
      </Demo>

      <!-- Skeleton -->
      <Demo title="Skeleton">
        <div class="space-y-3 max-w-sm">
          <div class="skeleton" style="width: 100%; height: 20px;"></div>
          <div class="skeleton" style="width: 80%; height: 20px;"></div>
          <div class="skeleton" style="width: 60%; height: 20px;"></div>
          <div class="flex items-center gap-3 mt-4">
            <div
              class="skeleton"
              style="width: 48px; height: 48px; border-radius: 50%;"
            >
            </div>
            <div class="flex-1 space-y-2">
              <div class="skeleton" style="width: 70%; height: 16px;"></div>
              <div class="skeleton" style="width: 50%; height: 14px;"></div>
            </div>
          </div>
        </div>
      </Demo>

      <!-- Progress -->
      <Demo title="Progress">
        <div class="space-y-4">
          <div class="progress progress-primary">
            <div class="progress-bar" style="width: 25%">
              <span class="progress-label">25%</span>
            </div>
          </div>
          <div class="progress progress-sm">
            <div class="progress-bar" style="width: 33%">
              <span class="progress-label">33%</span>
            </div>
          </div>
          <div class="progress progress-lg progress-danger">
            <div class="progress-bar" style="width: 45%">
              <span class="progress-label">45%</span>
            </div>
          </div>
          <div class="progress progress-success">
            <div class="progress-bar" style="width: 50%">
              <span class="progress-label">50%</span>
            </div>
          </div>
          <div class="progress progress-warning">
            <div class="progress-bar" style="width: 75%">
              <span class="progress-label">75%</span>
            </div>
          </div>
          <div
            class="progress progress-primary progress-striped progress-animated"
          >
            <div class="progress-bar" style="width: 60%"></div>
          </div>
          <div class="progress progress-info progress-indeterminate">
            <div class="progress-bar"></div>
          </div>
        </div>
      </Demo>

      <!-- Steps -->
      <Demo title="Steps">
        <div class="steps">
          <div class="step done">
            <a href="#" class="step-inner">
              <div class="step-indicator"></div>
              <div class="step-content">
                <div class="step-title">Account</div>
                <div class="step-description">Create your account</div>
              </div>
            </a>
          </div>
          <div class="step done">
            <a href="#" class="step-inner">
              <div class="step-indicator"></div>
              <div class="step-content">
                <div class="step-title">Profile</div>
                <div class="step-description">Set up your profile</div>
              </div>
            </a>
          </div>
          <div class="step active">
            <a href="#" class="step-inner">
              <div class="step-indicator"></div>
              <div class="step-content">
                <div class="step-title">Settings</div>
                <div class="step-description">Configure settings</div>
              </div>
            </a>
          </div>
          <div class="step">
            <a href="#" class="step-inner">
              <div class="step-indicator"></div>
              <div class="step-content">
                <div class="step-title">Review</div>
                <div class="step-description">Review and confirm</div>
              </div>
            </a>
          </div>
        </div>
      </Demo>

      <!-- Timeline -->
      <Demo title="Timeline">
        <div class="grid grid-cols-2">
          <div class="timeline">
            <div class="timeline-item">
              <div class="timeline-indicator bg-green-600">
                <i class="fas fa-check"></i>
              </div>
              <div class="timeline-content">
                <div class="timeline-title">Application Submitted</div>
                <div class="timeline-description">15th March 2024</div>
                <div class="timeline-body">
                  Your job application has been successfully submitted.
                </div>
              </div>
            </div>
            <div class="timeline-item timeline-item-completed">
              <div class="timeline-indicator">
                <i class="fas fa-check"></i>
              </div>
              <div class="timeline-content">
                <div class="timeline-title">Application Reviewed</div>
                <div class="timeline-description">18th March 2024</div>
                <div class="timeline-body">
                  Your application has been reviewed by the hiring team.
                </div>
              </div>
            </div>
            <div class="timeline-item timeline-item-active">
              <div class="timeline-indicator">
                <i class="fas fa-clock"></i>
              </div>
              <div class="timeline-content">
                <div class="timeline-title">Interview Scheduled</div>
                <div class="timeline-description">22nd March 2024</div>
                <div class="timeline-body">
                  Your interview has been scheduled.
                </div>
              </div>
            </div>
            <div class="timeline-item">
              <div class="timeline-indicator">
                <i class="fas fa-hourglass"></i>
              </div>
              <div class="timeline-content">
                <div class="timeline-title">Decision</div>
                <div class="timeline-body">Pending</div>
              </div>
            </div>
          </div>
          <div class="timeline">
            <div class="timeline-item">
              <div class="timeline-indicator bg-green-600">
                <i class="fas fa-check"></i>
              </div>
              <div class="timeline-content">
                <div class="flex items-center gap-2">
                  <div class="timeline-title">Application Submitted</div>
                  <span class="text-gray-500">&bullet;</span>
                  <div class="timeline-description">15th March 2024</div>
                </div>
                <div class="timeline-body">
                  Your job application has been successfully submitted.
                </div>
              </div>
            </div>
            <div class="timeline-item timeline-item-completed">
              <div class="timeline-indicator">
                <i class="fas fa-check"></i>
              </div>
              <div class="timeline-content">
                <div class="flex items-center gap-2">
                  <div class="timeline-title">Application Reviewed</div>
                  <span class="text-gray-500">&bullet;</span>
                  <div class="timeline-description">18th March 2024</div>
                </div>
                <div class="timeline-body">
                  Your application has been reviewed by the hiring team.
                </div>
              </div>
            </div>
            <div class="timeline-item timeline-item-active">
              <div class="timeline-indicator">
                <i class="fas fa-clock"></i>
              </div>
              <div class="timeline-content">
                <div class="flex items-center gap-2">
                  <div class="timeline-title">Interview Scheduled</div>
                  <span class="text-gray-500">&bullet;</span>
                  <div class="timeline-description">22nd March 2024</div>
                </div>
                <div class="timeline-body">
                  Your interview has been scheduled.
                </div>
              </div>
            </div>
            <div class="timeline-item">
              <div class="timeline-indicator">
                <i class="fas fa-hourglass"></i>
              </div>
              <div class="timeline-content">
                <div class="timeline-title">Decision</div>
                <div class="timeline-body">Pending</div>
              </div>
            </div>
          </div>
        </div>
      </Demo>

      <!-- Breadcrumb -->
      <Demo title="Breadcrumb">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="#">Home</a></li>
            <li class="breadcrumb-item breadcrumb-separator">
              <i class="fas fa-angle-right"></i>
            </li>
            <li class="breadcrumb-item"><a href="#">Library</a></li>
            <li class="breadcrumb-item breadcrumb-separator">
              <i class="fas fa-angle-right"></i>
            </li>
            <li class="breadcrumb-item"><a href="#">Category</a></li>
            <li class="breadcrumb-item breadcrumb-separator">
              <i class="fas fa-angle-right"></i>
            </li>
            <li class="breadcrumb-item active" aria-current="page">
              Current Page
            </li>
          </ol>
        </nav>
      </Demo>

      <!-- Pagination -->
      <Demo title="Pagination">
        <nav aria-label="Page navigation">
          <ul class="pagination">
            <li>
              <a class="page-item" href="#">
                <i class="fas fa-angle-double-left"></i>
              </a>
            </li>
            <li>
              <a class="page-item" href="#">
                <i class="fas fa-angle-left"></i>
              </a>
            </li>
            <li><a class="page-item" href="#">1</a></li>
            <li><a class="page-item active" href="#">2</a></li>
            <li><a class="page-item" href="#">3</a></li>
            <li><button class="page-item">...</button></li>
            <li><a class="page-item" href="#">10</a></li>
            <li>
              <a class="page-item" href="#">
                <i class="fas fa-angle-right"></i>
              </a>
            </li>
            <li>
              <a class="page-item" href="#">
                <i class="fas fa-angle-double-right"></i>
              </a>
            </li>
          </ul>
        </nav>
      </Demo>

      <!-- Tooltip -->
      <Demo title="Tooltip">
        <div class="flex flex-wrap items-center gap-3">
          <button class="btn btn-primary" data-tooltip="Hello World!">
            Hover me
          </button>
          <button class="btn btn-outline" data-tooltip="Another tooltip">
            Tooltip too
          </button>
          <span data-tooltip="Tooltips work on any element" class="underline">
            Hover this text
          </span>
        </div>
      </Demo>

      <!-- Copy Button -->
      <Demo title="Copy Button">
        <div class="flex items-center gap-3">
          <code class="px-3 py-1 bg-slate-100 rounded text-sm">
            npm install bloum
          </code>
          <bl-copy-button class="btn btn-icon btn-sm" value="npm install bloum">
            <i class="fas fa-clipboard"></i>
          </bl-copy-button>
        </div>
      </Demo>
    </Section>

    <!-- ==================== INPUTS ==================== -->
    <Section title="Inputs" id="inputs">
      <!-- Form Field -->
      <Demo title="Form Field">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="field">
            <label for="demo-email" class="label">Email</label>
            <input
              type="email"
              id="demo-email"
              class="input"
              placeholder="Enter your email"
            />
          </div>
          <div class="field field-success">
            <label for="demo-name" class="label">Name</label>
            <input type="text" id="demo-name" class="input" value="John Doe" />
            <p class="field-text-success">Looks good!</p>
          </div>
          <div class="field field-danger">
            <label for="demo-url" class="label">Website</label>
            <input type="url" id="demo-url" class="input" value="not-a-url" />
            <p class="field-text-danger">Please enter a valid URL.</p>
          </div>
          <div class="field">
            <label for="demo-disabled" class="label">Disabled</label>
            <input
              type="text"
              id="demo-disabled"
              class="input"
              disabled
              value="Can't edit this"
            />
          </div>
        </div>
      </Demo>

      <!-- Input with icon -->
      <Demo title="Input with Icon">
        <div class="max-w-md">
          <div class="input-icon">
            <div class="input-icon-addon">
              <i class="fas fa-search"></i>
            </div>
            <input type="text" class="input" placeholder="Search..." />
          </div>
        </div>
      </Demo>

      <!-- Password -->
      <Demo title="Password Input">
        <div class="max-w-md">
          <div class="field">
            <label for="demo-password" class="label">Password</label>
            <div class="input-icon">
              <input
                type="password"
                id="demo-password"
                class="input"
                placeholder="Enter your password"
                value="mypassword123"
              />
              <button type="button" class="password-toggle">
                <i class="fa-solid fa-eye"></i>
              </button>
            </div>
          </div>
        </div>
      </Demo>

      <!-- Checkbox -->
      <Demo title="Checkbox">
        <div class="space-y-3">
          <div class="field-check">
            <input type="checkbox" id="demo-cb1" class="input-check" />
            <label for="demo-cb1" class="input-check-label">
              Accept terms and conditions
            </label>
          </div>
          <div class="field-check">
            <input type="checkbox" id="demo-cb2" class="input-check" checked />
            <label for="demo-cb2" class="input-check-label">
              Subscribe to newsletter
            </label>
          </div>
          <div class="field-check">
            <input type="checkbox" id="demo-cb3" class="input-check" disabled />
            <label for="demo-cb3" class="input-check-label"
              >Disabled checkbox</label
            >
          </div>
        </div>
      </Demo>

      <!-- Radio -->
      <Demo title="Radio">
        <div class="space-y-3">
          <div class="field-check">
            <input
              type="radio"
              id="demo-radio1"
              name="demo-radio"
              class="input-check"
              checked
            />
            <label for="demo-radio1" class="input-check-label">Option A</label>
          </div>
          <div class="field-check">
            <input
              type="radio"
              id="demo-radio2"
              name="demo-radio"
              class="input-check"
            />
            <label for="demo-radio2" class="input-check-label">Option B</label>
          </div>
          <div class="field-check">
            <input
              type="radio"
              id="demo-radio3"
              name="demo-radio"
              class="input-check"
              disabled
            />
            <label for="demo-radio3" class="input-check-label">Option C</label>
          </div>
        </div>
      </Demo>

      <!-- Switch -->
      <Demo title="Switch">
        <div class="flex flex-col gap-3">
          <div class="field-switch">
            <input type="checkbox" class="switch" role="switch" id="demo-sw1" />
            <label for="demo-sw1" class="input-check-label"
              >Enable notifications</label
            >
          </div>
          <div class="field-switch">
            <input
              type="checkbox"
              class="switch"
              role="switch"
              id="demo-sw2"
              checked
            />
            <label for="demo-sw2" class="input-check-label">Dark mode</label>
          </div>
          <div class="field-switch">
            <input
              type="checkbox"
              class="switch"
              role="switch"
              id="demo-sw3"
              disabled
            />
            <label for="demo-sw3" class="input-check-label">Disabled</label>
          </div>
        </div>
      </Demo>

      <!-- Textarea -->
      <Demo title="Textarea">
        <div class="max-w-md space-y-4">
          <div class="field">
            <label for="demo-textarea" class="label">Message</label>
            <textarea
              class="input"
              id="demo-textarea"
              rows="3"
              placeholder="Enter your message..."></textarea>
          </div>
          <div class="field">
            <label for="demo-autogrow" class="label">
              Auto-growing Textarea
            </label>
            <textarea
              class="input"
              id="demo-autogrow"
              data-autogrow
