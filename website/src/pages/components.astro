        <script>
          import { Combobox, DataTable, Toast } from "../../../src";

          // Initialize Combobox
          const comboboxEl = document.querySelector("#demo-combobox") as any;
          if (comboboxEl) {
            new Combobox(comboboxEl, { isSearchable: true });
          }

          // Initialize DataTable
          const datatableEl = document.querySelector("#demo-datatable") as any;
          if (datatableEl) {
            new DataTable(datatableEl);
          }

          // Toast demo buttons
          document
            .getElementById("toast-default")
            ?.addEventListener("click", () => {
              Toast.show({
                title: "Default",
                description: "This is a default toast notification.",
                variant: "default",
                placement: "top-right",
              });
            });

          document
            .getElementById("toast-primary")
            ?.addEventListener("click", () => {
              Toast.show({
                title: "Info",
                description: "Here is some useful information.",
                variant: "primary",
                placement: "top-right",
              });
            });

          document
            .getElementById("toast-success")
            ?.addEventListener("click", () => {
              Toast.show({
                title: "Success!",
                description: "Your changes have been saved.",
                variant: "success",
                placement: "top-right",
              });
            });

          document
            .getElementById("toast-danger")
            ?.addEventListener("click", () => {
              Toast.show({
                title: "Error",
                description: "Something went wrong. Please try again.",
                variant: "danger",
                placement: "top-right",
              });
            });

          document
            .getElementById("toast-warning")
            ?.addEventListener("click", () => {
              Toast.show({
                title: "Warning",
                description: "Please review before proceeding.",
                variant: "warning",
                placement: "top-right",
              });
            });
        </script>
